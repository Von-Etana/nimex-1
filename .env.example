# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_web_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_FUNCTIONS_REGION=us-east4

# Firebase Emulator (for local development)
VITE_USE_FIREBASE_EMULATOR=false

# Clerk Authentication (DEMO - Replace with real keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YWxlcnQtbWFybGluLTIxLmNsZXJrLmFjY291bnRzLmRldiQ

# Resend Email Service
# Keep Resend credentials server-side only. Set Firebase Functions config/env:
#   firebase functions:config:set resend.api_key="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL=NIMEX <noreply@nimex.ng>

# Paystack Payment Gateway
VITE_PAYSTACK_PUBLIC_KEY=pk_test_or_live_public_key
VITE_PAYSTACK_TEST_MODE=false

# Terminal Africa Logistics API
VITE_TERMINAL_BASE_URL=https://sandbox.terminal.africa/v1
# Keep Terminal secret/webhook credentials server-side only:
#   firebase functions:config:set terminal.api_key="..."
#   firebase functions:config:set terminal.webhook_secret="..."

# Flutterwave Payment & Wallet
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_or_live_public_key
VITE_FLUTTERWAVE_API_URL=https://api.flutterwave.com/v3
VITE_FLUTTERWAVE_TEST_MODE=true

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your_browser_restricted_google_maps_key
